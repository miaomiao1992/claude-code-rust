    "react-hook-form": "^7.49.2",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.0.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "remark-gfm": "^4.0.0",
    "sonner": "^1.3.1",
    "tailwind-merge": "^2.2.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  }
